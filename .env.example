# MirrAI (sAIon) Project Environment Variables Template
# 이 파일을 .env로 복사하여 실제 값을 입력해 주세요. (보안 주의)

# [API Server]
BACKEND_API_URL=http://localhost:8000/api/v1

# [AI Models & External APIs]
OPENAI_API_KEY=your_openai_api_key_here
STABLE_DIFFUSION_ENDPOINT=your_sd_endpoint_here
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_TRENDS_ENDPOINT_ID=your_runpod_trend_endpoint_id_here
RUNPOD_BASE_URL=https://api.runpod.ai/v2

# [Security & Database]
JWT_SECRET_KEY=your_super_secret_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/mirrai_db

# [Cloud Infrastructure - S3]
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=mirrai-customer-profiles
S3_REGION=ap-northeast-2

# [Frontend]
PORT=3000
NODE_ENV=development

# [crawling]
GEMINI_API_KEY=your_gemini_api_key_here

# [Trend scheduler]
ENABLE_TREND_SCHEDULER=false
TREND_SCHEDULER_TIMEZONE=Asia/Seoul
TREND_SCHEDULER_WEEKLY_DAY=fri
TREND_SCHEDULER_WEEKLY_HOUR=8
TREND_SCHEDULER_WEEKLY_MINUTE=0
TREND_SCHEDULER_STEPS=crawl,refine,llm_refine,vectorize,rebuild_styles
TREND_SCHEDULER_INCLUDE_NCS=false
TREND_SCHEDULER_INCLUDE_STYLES=false
TREND_SCHEDULER_TIMEOUT=1800
TREND_SCHEDULER_POLL_INTERVAL=5
TREND_SCHEDULER_SLEEP_INTERVAL=15
TREND_SCHEDULER_TEST_AT=
