# MirrAI (sAIon) Project Environment Variables Template
# 이 파일을 .env로 복사하여 실제 값을 입력해 주세요. (보안 주의)

# [API Server]
BACKEND_API_URL=http://localhost:8000/api/v1

# [AI Models & External APIs]
OPENAI_API_KEY=your_openai_api_key_here
STABLE_DIFFUSION_ENDPOINT=your_sd_endpoint_here

# [Security & Database]
JWT_SECRET_KEY=your_super_secret_key_here
DATABASE_URL=postgresql://user:password@localhost:5432/mirrai_db

# [Cloud Infrastructure - S3]
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=mirrai-customer-profiles
S3_REGION=ap-northeast-2

# [Frontend]
PORT=3000
NODE_ENV=development
