# Django (Elastic Beanstalk) environment template
# Copy to backend/.env and replace with real values.

# Core
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-eb-env.ap-northeast-2.elasticbeanstalk.com,your-domain.com

# Database switch
SUPABASE_USE_REMOTE_DB=False
LOCAL_DATABASE_URL=sqlite:///db.sqlite3
SUPABASE_DB_URL=

# Supabase (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=mirrai-assets
SUPABASE_USE_REMOTE_STORAGE=False
SUPABASE_BUCKET_PUBLIC=False
SUPABASE_SIGNED_URL_EXPIRES_IN=3600
SUPABASE_BUCKET_FILE_SIZE_LIMIT=10485760
SUPABASE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# Feature flags
MIRRAI_PERSIST_CAPTURE_IMAGES=False
